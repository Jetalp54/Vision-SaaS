# ─── Cloudflare Account ───────────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=8ec9c2ec64b71344b4750c357dfca2bd
CLOUDFLARE_API_TOKEN=                    # wrangler login OR create token with Workers+Pages+D1+R2 perms

# ─── D1 Database ──────────────────────────────────────────────────────────────
D1_DATABASE_ID=009763b6-4195-4b38-b8f2-207ee6686595

# ─── Workers KV ───────────────────────────────────────────────────────────────
KV_NAMESPACE_ID=491ff89e5b1b4551b66492df3536cf5b
KV_PREVIEW_NAMESPACE_ID=48e50782f4d34a84a85a3ac2eab24177

# ─── R2 Object Storage ────────────────────────────────────────────────────────
# Get these from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL=https://your-r2-public.r2.dev

# ─── Cloudflare AI Gateway ────────────────────────────────────────────────────
# Dashboard → AI Gateway → Create Gateway → copy Account ID + Gateway ID
AI_GATEWAY_ACCOUNT_ID=8ec9c2ec64b71344b4750c357dfca2bd
AI_GATEWAY_ID=vision-saas-gateway

# ─── Cloudflare Access (JWT Auth) ─────────────────────────────────────────────
# Dashboard → Zero Trust → Access → Applications
# Leave blank to use X-User-ID header in development
CF_ACCESS_TEAM_DOMAIN=                   # e.g. myteam
CF_ACCESS_AUD=                           # Application Audience Tag (AUD)

# ─── Frontend (Next.js) ───────────────────────────────────────────────────────
# These are baked into the static build — set them in Cloudflare Pages dashboard too
NEXT_PUBLIC_API_URL=https://vision-saas-api.abdo-charhamane.workers.dev
NEXT_PUBLIC_R2_PUBLIC_URL=https://your-r2-public.r2.dev

# ─── GitHub Actions Secrets (add these in GitHub → Settings → Secrets) ────────
# CLOUDFLARE_API_TOKEN     (same as above)
# CLOUDFLARE_ACCOUNT_ID    (same as above)
# PRODUCTION_API_URL       = https://vision-saas-api.abdo-charhamane.workers.dev
# PRODUCTION_R2_URL        = https://your-r2-public.r2.dev
# STAGING_API_URL          = https://vision-saas-api-staging.abdo-charhamane.workers.dev
