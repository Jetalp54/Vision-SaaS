{
  "name": "vision-saas",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "npx rimraf node_modules package-lock.json",
    "fresh-install": "npm run clean && npm install",
    "build:pages": "turbo run build --filter=@vision-saas/web",
    "db:generate": "turbo run db:generate --filter=@vision-saas/api",
    "db:migrate:local": "turbo run db:migrate:local --filter=@vision-saas/api",
    "db:migrate:prod": "turbo run db:migrate:prod --filter=@vision-saas/api",
    "deploy:api": "turbo run deploy --filter=@vision-saas/api",
    "deploy:web": "turbo run deploy --filter=@vision-saas/web"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.9.2"
}
